# Core AI provider
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:12b
# Disable reasoning/thinking mode for models like qwen3.* so JSON lands in `response` instead of `thinking`.
OLLAMA_DISABLE_THINKING=true
OLLAMA_CHUNK_SECONDS=180
OLLAMA_CHUNK_OVERLAP_SECONDS=20
OLLAMA_RETRIES=2
OLLAMA_RETRY_DELAY_SECONDS=20
OLLAMA_REQUEST_TIMEOUT_SECONDS=1800
OLLAMA_WARMUP_TIMEOUT_SECONDS=300
OLLAMA_KEEP_ALIVE=30m
OLLAMA_MAX_SEGMENT_LINES=90
OLLAMA_MAX_PROMPT_CHARS=14000

# Clip generation
MAX_GENERATED_CLIPS=10
MIN_CLIP_DURATION=60
MAX_CLIP_DURATION=180
PREFERRED_MIN_CLIP_DURATION=90
MAX_LONG_CLIP_DURATION=180
# Extra transcript on both sides of chunk focus windows for setup/payoff review.
CLIP_BOUNDARY_CONTEXT_SECONDS=30
# Maximum local search around proposed timestamps for sentence/pause boundaries.
CLIP_BOUNDARY_SEARCH_SECONDS=14
CLIP_BOUNDARY_MIN_PAUSE_SECONDS=0.7
CLIP_BOUNDARY_START_PAD_SECONDS=0.18
CLIP_BOUNDARY_END_PAD_SECONDS=0.28
MINIMAX_MODEL=MiniMax-M3
MINIMAX_CHUNK_SECONDS=360
MINIMAX_CHUNK_OVERLAP_SECONDS=45
MINIMAX_REQUEST_TIMEOUT_SECONDS=240
MINIMAX_CONTEXT_SUMMARY_MAX_CHARS=200000
MINIMAX_FORCE_CHUNKED=true
MINIMAX_USE_REMOTE_SUMMARY=false
MINIMAX_ALLOW_FULL_FALLBACK=false
MINIMAX_JSON_MAX_TOKENS=8000
MINIMAX_THINKING_TYPE=disabled
TIGHT_EDIT_PRESET=aggressive

# Source download quality
PREFERRED_DOWNLOAD_HEIGHT=1080
MIN_SOURCE_EDGE=720
SETTINGS_SYNC_DIR=/app/output/.settings_sync
SETTINGS_SYNC_TTL_DAYS=365
SETTINGS_SYNC_MAX_BYTES=262144

# Longform storage
# Temporary longform uploads are now stored on the bind-mounted app volume instead of the container layer.
LONGFORM_UPLOAD_TMP_ROOT=/app/output/.longform_uploads
# Default without recreate: use files placed under ./output/longform_source_mount
# Optional for external drives: set LONGFORM_SOURCE_HOST_DIR to e.g. /media/usb1 and recreate containers.
LONGFORM_SOURCE_HOST_DIR=./output/longform_source_mount
LONGFORM_SOURCE_MOUNT_ROOT=/mnt/longform-source
LONGFORM_ALLOWED_SOURCE_ROOTS=/mnt/longform-source

# YouTube cookies / tokens
# Prefer a local cookies.txt in the project root. These are optional fallbacks.
YOUTUBE_AUTH_MODE=auto
YOUTUBE_COOKIES_FILE=/app/cookies.txt
# YOUTUBE_COOKIES_FROM_BROWSER=chrome
# YOUTUBE_COOKIES=
# YOUTUBE_VISITOR_DATA=
# YOUTUBE_PO_TOKEN_WEB=
# YOUTUBE_PO_TOKEN_MWEB=
# YOUTUBE_PO_TOKEN_ANDROID=
# YOUTUBE_PO_TOKENS=

# Video output
TARGET_VERTICAL_WIDTH=1080
TARGET_VERTICAL_HEIGHT=1920
YOLO_MODEL_PATH=/tmp/Ultralytics/yolov8n.pt

# Ultra-fast draft preview render (for positioning only)
PREVIEW_SAMPLE_SECONDS=1.0
PREVIEW_RENDER_WIDTH=360
PREVIEW_RENDER_HEIGHT=640
PREVIEW_TRIM_PRESET=ultrafast
PREVIEW_VERTICAL_PRESET=ultrafast
PREVIEW_RENDER_CRF=34
PREVIEW_RENDER_MAXRATE=1M
PREVIEW_RENDER_BUFSIZE=2M
PREVIEW_AUDIO_BITRATE=96k

# Browser preview proxies for draft clips. These are intentionally tiny and created only on explicit click.
BROWSER_PREVIEW_CONCURRENCY=1
BROWSER_PREVIEW_THREADS=2
BROWSER_PREVIEW_WIDTH=360
BROWSER_PREVIEW_FPS=12
BROWSER_PREVIEW_PRESET=ultrafast
BROWSER_PREVIEW_CRF=38
BROWSER_PREVIEW_MAXRATE=600k
BROWSER_PREVIEW_BUFSIZE=1200k
BROWSER_PREVIEW_AUDIO_BITRATE=64k

# Runtime limits
MAX_CONCURRENT_JOBS=1
JOB_NICE_LEVEL=0
FFMPEG_THREADS=16
FFMPEG_FILTER_THREADS=8
FFMPEG_PRESET=fast
OVERLAY_FFMPEG_PRESET=veryfast
# auto uses NVIDIA NVENC after a real encoder preflight and falls back to libx264.
SHORTFORM_VIDEO_ENCODER=auto
NVENC_PRESET=p4
NVENC_CQ=18
# Face detection is sampled; camera motion is interpolated on the frames between samples.
TRACKING_DETECTION_FPS=10
# Scratch stays on the Linux filesystem; the persistent cache is a Docker named volume.
RENDER_SCRATCH_DIR=/tmp/openshorts-render
RENDER_CACHE_DIR=/var/cache/openshorts/render
WHISPER_CPU_THREADS=16
OMP_NUM_THREADS=16
OPENBLAS_NUM_THREADS=1
MKL_NUM_THREADS=1
NUMEXPR_NUM_THREADS=1
JOB_RETENTION_SECONDS=604800

# Whisper runtime (quality/safety tuning)
# Prefer CUDA by default; runtime falls back to CPU safe mode if GPU init fails.
WHISPER_DEVICE=cuda
# Better default than base while still performant. Falls back automatically in safe mode.
WHISPER_MODEL=distil-large-v3
# Preferred model when runtime falls back to CPU (keeps transcription much faster than large-v3 on CPU).
WHISPER_CPU_MODEL=distil-large-v3
# Preferred model for German transcription.
WHISPER_MODEL_DE=primeline/whisper-large-v3-german
# CPU fallback model for German transcription.
WHISPER_CPU_MODEL_DE=primeline/whisper-large-v3-german
# Preferred model for non-English transcription (e.g. German).
WHISPER_MODEL_NON_EN=large-v3
# CPU fallback model for non-English transcription.
WHISPER_CPU_MODEL_NON_EN=large-v3
# Auto-convert HuggingFace Transformer checkpoints (without model.bin) to CTranslate2 for faster-whisper.
WHISPER_HF_CONVERT_ENABLED=true
# Optional explicit quantization for conversion (e.g. int8, int8_float16). Leave empty for full precision conversion.
WHISPER_HF_CONVERT_QUANTIZATION=
# Persistent model caches. These live in the bind-mounted project output so moving the disk
# to another machine does not force HuggingFace/faster-whisper downloads and CT2 conversion again.
WHISPER_HF_CONVERT_CACHE_DIR=/app/output/.cache/whisper_ct2
HF_HOME=/app/output/.cache/huggingface
HUGGINGFACE_HUB_CACHE=/app/output/.cache/huggingface/hub
TRANSFORMERS_CACHE=/app/output/.cache/huggingface/transformers
# If true, and WHISPER_MODEL is a large-v3 variant, CPU mode will prioritize WHISPER_CPU_MODEL automatically.
WHISPER_CPU_AUTO_DISTIL=true
WHISPER_MODEL_FALLBACKS=medium,small,base
WHISPER_CUDA_MODEL_FALLBACKS=large-v3,medium,small,base
WHISPER_COMPUTE_TYPE=auto
WHISPER_SAFE_MODE=true
WHISPER_SAFE_VRAM_MARGIN_MB=512
WHISPER_NUM_WORKERS=1
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
# Leave empty or set to "auto" for auto-detect; set e.g. "de" to force German transcription.
WHISPER_LANGUAGE=de
# Optional language hints for auto mode. If detection lands outside this list with low confidence,
# the first hint is used for a retry. Example: de,en
WHISPER_LANGUAGE_HINTS=de
WHISPER_LANGUAGE_RETRY_ENABLED=true
WHISPER_LANGUAGE_RETRY_MAX_PROBABILITY=0.92

# Optional Upload-Post
# This project mainly stores these in the UI, but you can keep them here for backend-side use if needed.
# UPLOAD_POST_API_KEY=
# UPLOAD_POST_USER_ID=

# Docker DNS override
# Set these if containers start with an empty/broken /etc/resolv.conf and cannot resolve external hosts.
DOCKER_DNS_1=1.1.1.1
DOCKER_DNS_2=8.8.8.8

# ElevenLabs
# ELEVENLABS_API_KEY=

# Optional S3 backup
# Leave empty to disable.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=openshorts.app-clips
